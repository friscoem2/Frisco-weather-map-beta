function getPropNumber(p,names){
  const v=getFirstProp(p,names);
  if(v===null||v===undefined) return null;
  const m=String(v).match(/-?\d+(?:\.\d+)?/);
  return m ? Number(m[0]) : null;
}
function getStormCellId(p,idx){
  return String(getFirstProp(p,['id','ID','cell_id','CELL_ID','storm_id','STORM_ID','stormid','STORMID','ident','IDENT','name','NAME']) || ('C'+(idx+1))).slice(0,4).toUpperCase();
}
function destinationPoint(lat,lon,bearingDeg,distanceKm){
  const R=6371.0088, br=bearingDeg*Math.PI/180, φ1=lat*Math.PI/180, λ1=lon*Math.PI/180, δ=distanceKm/R;
  const sinφ2=Math.sin(φ1)*Math.cos(δ)+Math.cos(φ1)*Math.sin(δ)*Math.cos(br);
  const φ2=Math.asin(sinφ2);
  const y=Math.sin(br)*Math.sin(δ)*Math.cos(φ1);
  const x=Math.cos(δ)-Math.sin(φ1)*Math.sin(φ2);
  const λ2=λ1+Math.atan2(y,x);
  return [φ2*180/Math.PI, ((λ2*180/Math.PI+540)%360)-180];
}
