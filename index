async function loadScitOverlay(){
  if(!scitOn) return;
  const station=currentRadarStation();
  if(!station) return;
  if(scitFetchController) scitFetchController.abort();
  scitFetchController=new AbortController();
  setOverlayStatus('Checking SCIT availability for '+station.id.toUpperCase()+'…');
  try{
    const available=await stationHasWfsFeatureTypes(station.id,[/scit/i,/storm/i,/cell/i],scitFetchController);
    if(!available){ scitLayer.clearLayers(); setOverlayStatus('SCIT WFS is not published by OpenGeo for '+station.id.toUpperCase()+'.'); stopScitPoll(); return; }
    setOverlayStatus('Loading SCIT cells for '+station.id.toUpperCase()+'…');
    const url=stationWfsUrl(station.id, station.id+'_scit');
    const data=await fetchGeoJson(url, scitFetchController);
    scitLayer.clearLayers();
    let count=0;
    (data.features||[]).forEach((f,idx)=>{
      const ll=featureLatLng(f); if(!ll) return;
      const p=f.properties||{};
      const id=getStormCellId(p,idx);
      const dir=getPropNumber(p,['direction','Direction','motion_direction','MOTION_DIRECTION','azimuth','AZIMUTH','dir','DIR']);
      const kts=getPropNumber(p,['speed','Speed','motion_speed','MOTION_SPEED','spd','SPD','knots','KTS']);
      const top=getFirstProp(p,['storm_top','STORM_TOP','top','TOP','tops','TOPS','height','HEIGHT']) || '—';
      const dbz=getFirstProp(p,['max_dbz','MAX_DBZ','dbz','DBZ','max_reflectivity','MAX_REFLECTIVITY']) || '—';
      const vil=getFirstProp(p,['vil','VIL','max_vil','MAX_VIL']) || '—';
      const group=L.featureGroup();
      const marker=L.marker(ll,{icon:scitLabelIcon(id),zIndexOffset:760}).addTo(group);
      const forecast=[];
      if(Number.isFinite(dir)&&Number.isFinite(kts)){
        [15,30,45].forEach(min=>{
          const km=kts*1.852*(min/60);
          const pt=destinationPoint(ll[0],ll[1],dir,km);
          forecast.push({min,pt});
        });
        L.polyline([ll,...forecast.map(x=>x.pt)],{color:'rgba(255,234,0,.7)',weight:1.5,dashArray:'6 4',interactive:false}).addTo(group);
        forecast.forEach(x=>{
          L.circleMarker(x.pt,{radius:3,color:'#ffea00',weight:1,fillColor:'#ffea00',fillOpacity:.65}).addTo(group);
          L.marker(x.pt,{icon:scitTimeIcon('+'+x.min),interactive:false,zIndexOffset:740}).addTo(group);
        });
      }
      const posTxt=forecast.length ? forecast.map(x=>'+'+x.min+': '+x.pt[0].toFixed(3)+', '+x.pt[1].toFixed(3)).join('<br>') : '+15/+30/+45: unavailable';
      marker.bindPopup('<b style="color:#ffea00">STORM CELL '+escapeHTML(id)+'</b><br>Motion: '+(Number.isFinite(dir)?dir.toFixed(0)+'°':'—')+' at '+(Number.isFinite(kts)?kts.toFixed(0)+' kts':'—')+'<br>Storm Top: '+escapeHTML(top)+'<br>Max dBZ: '+escapeHTML(dbz)+'<br>Max VIL: '+escapeHTML(vil)+'<br>'+posTxt+'<br><span style="color:rgba(160,200,225,.55)">Station: '+station.id.toUpperCase()+'</span>');
      group.addTo(scitLayer);
      count++;
    });
    setOverlayStatus(count ? count+' storm cells tracked · '+station.id.toUpperCase() : 'No SCIT storm cells for '+station.id.toUpperCase());
    debugLog('SCIT','Rendered '+count+' storm cells', {station:station.id});
  }catch(err){
    if(err.name==='AbortError') return;
    console.warn('SCIT load failed:',err);
    debugLog('SCIT','Load failed. OpenGeo WFS may not publish station SCIT.',err,'warn');
    setOverlayStatus('No SCIT storm cells for '+(currentRadarStation()?.id||selectedVelStation).toUpperCase());
  }
}
