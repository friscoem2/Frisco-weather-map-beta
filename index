const stationWfsAvailabilityCache = new Map();
async function stationHasWfsFeatureTypes(stationId, patterns, controller){
  const key=stationId+'|'+patterns.map(p=>p.source).join(',');
  if(stationWfsAvailabilityCache.has(key)) return stationWfsAvailabilityCache.get(key);
  try{
    const url=NWS_BASE + '/' + stationId + '/ows?service=WFS&version=2.0.0&request=GetCapabilities&_=' + Date.now();
    const res=await fetchWithTimeout(url,{cache:'no-store',signal:controller&&controller.signal},9000);
    if(!res.ok) throw new Error('WFS capabilities failed '+res.status);
    const text=await res.text();
    const doc=new DOMParser().parseFromString(text,'text/xml');
    const names=Array.from(doc.getElementsByTagName('Name')).map(n=>n.textContent.trim().toLowerCase());
    const matches=names.filter(n=>patterns.some(p=>p.test(n)));
    const ok=matches.length>0;
    stationWfsAvailabilityCache.set(key,ok);
    debugLog('WFS AVAILABILITY',stationId.toUpperCase()+' '+(ok?'has':'does not publish')+' requested feature family',{matches:matches.slice(0,40)},ok?'info':'warn');
    return ok;
  }catch(err){
    if(err.name==='AbortError') throw err;
    debugLog('WFS AVAILABILITY','Could not verify WFS feature types for '+stationId,err,'warn');
    return true;
  }
}
function stationWfsUrl(stationId,typeName){ return NWS_BASE + '/' + stationId + '/ows?service=WFS&version=2.0.0&request=GetFeature&typeName=' + typeName + '&outputFormat=application/json'; }
function featureLatLng(feature){
  const g=feature && feature.geometry; if(!g) return null;
  let c=g.coordinates;
  if(g.type==='Point') return [c[1],c[0]];
  while(Array.isArray(c) && Array.isArray(c[0]) && typeof c[0][0] !== 'number') c=c[0];
  if(Array.isArray(c)&&Array.isArray(c[0])){let sx=0,sy=0,n=0;c.forEach(p=>{sx+=p[0];sy+=p[1];n++;}); if(n) return [sy/n,sx/n];}
  return null;
}
function getFirstProp(p,names){ for(const n of names){ if(p && p[n]!==undefined && p[n]!==null && p[n] !== '') return p[n]; } return null; }
async function fetchGeoJson(url, controller){
  const started=performance.now();
  debugLog('GEOJSON FETCH','GET '+url);
  const res=await fetch(url,{cache:'no-store',signal:controller.signal});
  const text=await res.text();
  debugLog('GEOJSON FETCH','HTTP '+res.status+' · '+Math.round(performance.now()-started)+'ms · '+text.length+' bytes', text.slice(0,500), res.ok?'info':'error');
  if(!res.ok) throw new Error('Fetch failed '+res.status+' for '+url);
  try { const data=JSON.parse(text); debugLog('GEOJSON FETCH','Parsed features: '+((data.features||[]).length), {url}); return data; }
  catch(e){ debugLog('GEOJSON FETCH','JSON parse failed', {url, sample:text.slice(0,800)}, 'error'); throw e; }
}

