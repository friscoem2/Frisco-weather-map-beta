function lightningTimeToMs(v){
  let tm=Number(v);
  if(!Number.isFinite(tm)) return Date.now();
  if(tm>1e15) tm=Math.floor(tm/1e6);
  else if(tm>1e12) tm=Math.floor(tm);
  else if(tm>1e9) tm=Math.floor(tm*1000);
  return tm;
}
function extractLightningStrikes(payload){
  const out=[]; const seen=new Set();
  function walk(x,depth){
    if(!x || depth>5) return;
    if(typeof x==='string'){try{walk(JSON.parse(x),depth+1);}catch(_){} return;}
    if(Array.isArray(x)){x.forEach(v=>walk(v,depth+1)); return;}
    if(typeof x==='object'){
      const lat=Number(x.lat ?? x.latitude ?? x.y ?? x.la);
      const lon=Number(x.lon ?? x.lng ?? x.longitude ?? x.x ?? x.lo);
      if(Number.isFinite(lat)&&Number.isFinite(lon)&&lat>=-90&&lat<=90&&lon>=-180&&lon<=180){
        const time=lightningTimeToMs(x.time ?? x.t ?? x.timestamp ?? x.date ?? x.stime);
        const key=lat.toFixed(4)+','+lon.toFixed(4)+','+time;
        if(!seen.has(key)){seen.add(key);out.push({lat,lon,time});}
      }
      ['strike','strikes','data','features','items','rows','result'].forEach(k=>{if(x[k])walk(x[k],depth+1);});
      if(x.geometry && Array.isArray(x.geometry.coordinates)){
        const c=x.geometry.coordinates, lon2=Number(c[0]), lat2=Number(c[1]);
        if(Number.isFinite(lat2)&&Number.isFinite(lon2)) out.push({lat:lat2,lon:lon2,time:lightningTimeToMs(x.properties&&x.properties.time)});
      }
    }
  }
  walk(payload,0); return out;
}
function handleLightningPayload(raw){
  let payload=raw;
  if(typeof payload==='string'){
    try{payload=JSON.parse(payload);}catch(err){debugLog('LIGHTNING','Message was not JSON',raw.slice(0,700),'warn');return;}
  }
  const strikes=extractLightningStrikes(payload);
  if(!strikes.length){debugLog('LIGHTNING','Message parsed but no strike coordinates found',payload,'warn');return;}
  lightningLastMessageAt=Date.now();
  strikes.forEach(s=>lightningBuffer.push(s));
  pruneLightning(); lightningRenderDirty=true; updateLightningUi('LIVE'); updateDebugStatusLine();
  if(lightningBuffer.length <= strikes.length + 5) debugLog('LIGHTNING','Strike message accepted',{added:strikes.length,total:lightningBuffer.length,sample:strikes[0]});
}
