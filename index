    infraLayers[k].clearLayers(); infraCounts[k]=0;
    (data.features||[]).forEach(f=>{const ll=featureLatLng(f); if(!ll)return; const p=f.properties||{}; infraCounts[k]++; const nm=p[cfg.label]||p.NAME||p.FACILITYNAME||p.STRUCNAME||p.slr_0p8ft||p.SITE_NAME||p.FACILITY||'Unknown'; const addr=p.ADDRESS||p.ADDRESS1||p.STREET||p.CITY||p.CITY_NAME||p.ADDR||''; L.marker(ll,{icon:infraIcon(cfg),zIndexOffset:620}).bindPopup('<b style="color:'+cfg.color+'">'+escapeHTML(nm)+'</b><br>'+escapeHTML(addr||'—')+'<br>'+cfg.name.toUpperCase()+'<br><span style="color:rgba(160,200,225,.55)">SRC: '+escapeHTML(data._sourceUrl||'ArcGIS')+'</span>').addTo(infraLayers[k]);});
    debugLog('INFRA','Rendered '+infraCounts[k]+' '+k, {source:data._sourceUrl});
    if(!map.hasLayer(infraLayers[k]))infraLayers[k].addTo(map);
  });
  updateInfraButtons(); updateDebugStatusLine();
  const total=Object.values(infraCounts).reduce((a,b)=>a+b,0);
  document.getElementById('infra-status').textContent=okCount ? ('Infrastructure loaded: '+total+' feature(s) in current map view. Failed categories will be listed in DEBUG.') : 'Infrastructure could not be loaded. Open DEBUG → TEST INFRA for endpoint details.';
}
