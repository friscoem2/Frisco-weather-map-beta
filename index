function debugLog(system, message, data, level) {
  const row = { t:new Date().toLocaleTimeString('en-US',{timeZone:'America/Chicago',hour12:false}), system, message, data:data===undefined?'':safeDebugString(data), level:level||'info' };
  debugLogBuffer.push(row); if(debugLogBuffer.length>350) debugLogBuffer.shift();
  const body=document.getElementById('debug-body');
  if(body){
    const div=document.createElement('div'); div.className='debug-line '+(row.level==='error'?'err':row.level==='warn'?'warn':'');
    div.innerHTML='<b>['+row.t+'] '+escapeHTML(system)+':</b> '+escapeHTML(message)+(row.data?'<div class="debug-json">'+escapeHTML(row.data)+'</div>':'');
    body.appendChild(div);
    while(body.children.length>170) body.removeChild(body.firstChild);
    body.scrollTop=body.scrollHeight;
  }
  updateDebugStatusLine();
  try { (level==='error'?console.warn:console.log)('[DEBUG '+system+'] '+message, data || ''); } catch(_) {}
}
