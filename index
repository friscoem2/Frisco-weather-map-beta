async function debugCheckWmsLayer(url, layerName, force) {
  const key=url+'|'+layerName;
  if(debugWmsChecked.has(key) && !force) return;
  debugWmsChecked.add(key);
  try{
    const text=await debugFetchText(url+'?service=WMS&version=1.3.0&request=GetCapabilities&_='+Date.now(), 'WMS CAPABILITIES');
    const doc=new DOMParser().parseFromString(text,'text/xml');
    const names=Array.from(doc.getElementsByTagName('Name')).map(n=>n.textContent.trim()).filter(Boolean);
    const found=names.includes(layerName);
    const token=String(layerName).replace(/^k[a-z0-9]{3}_?/i,'').replace(/^_/,'').toLowerCase();
    const related=names.filter(n=>n.toLowerCase().includes(token)||n.toLowerCase().includes(String(layerName).toLowerCase().slice(-4))).slice(0,40);
    debugLog('WMS LAYER', (found?'FOUND ':'MISSING ')+layerName, {url, requested:layerName, related});
    if(!found) setOverlayStatus('Layer not listed in WMS capabilities: '+layerName+'. Open DEBUG → TEST RADAR for related layer names.');
