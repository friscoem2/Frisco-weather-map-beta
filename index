<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Frisco E.M.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
:root {
  --bg: #070c14;
  --surface: rgba(8,15,26,0.93);
  --surface2: rgba(10,20,36,0.97);
  --border: rgba(0,170,240,0.18);
  --border-hi: rgba(0,200,255,0.45);
  --accent: #00c8ff;
  --warn: #ff6b00;
  --danger: #ff1744;
  --safe: #00e676;
  --watch: #ffea00;
  --text: #b8d4e8;
  --text-dim: rgba(160,200,225,0.45);
  --text-hi: #e4f2ff;
  --glow: 0 0 18px rgba(0,200,255,0.25);
  --glow-danger: 0 0 22px rgba(255,23,68,0.55);
  --fd: 'Rajdhani', sans-serif;
  --fm: 'JetBrains Mono', monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100vw;height:100vh;overflow:hidden;font-family:var(--fd);background:var(--bg);color:var(--text)}
/* MAP */

/* SPLIT RADAR VIEW */
#map{
  transition:left .2s ease,width .2s ease;
}

#compare-map{
  display:none;
  position:absolute;
  top:0;
  right:0;
  bottom:0;
  width:50%;
  z-index:1;
  border-left:1px solid rgba(0,200,255,.35);
  background:#050a12;
}

body.split-view #map{
  left:0;
  right:auto;
  width:50%;
}

body.split-view #compare-map{
  display:block;
}

.split-label{
  position:absolute;
  top:56px;
  z-index:850;
  font-family:var(--fm);
  font-size:10px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  color:var(--accent);
  background:rgba(5,10,18,.82);
  border:1px solid var(--border);
  border-radius:3px;
  padding:5px 8px;
  pointer-events:none;
  backdrop-filter:blur(10px);
}

#left-map-label{
  display:none;
  left:12px;
}

#right-map-label{
  display:none;
  right:12px;
}

body.split-view #left-map-label,
body.split-view #right-map-label{
  display:block;
}

.lbtn.on.watch-yellow{
  border-color:#ffea00;
  color:#ffea00;
  background:rgba(255,234,0,.10);
  box-shadow:0 0 8px rgba(255,234,0,.18);
}

#map{position:absolute;inset:0;z-index:1}
#topbar{
  position:absolute;top:0;left:0;right:0;z-index:1000;
  height:48px;
  background:linear-gradient(180deg,rgba(5,10,18,.98) 0%,rgba(5,10,18,.75) 100%);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 14px;gap:16px;
  backdrop-filter:blur(14px);
}
.logo{font-family:var(--fd);font-size:17px;font-weight:700;letter-spacing:3px;color:var(--accent);text-shadow:0 0 16px rgba(0,200,255,.4);white-space:nowrap;flex-shrink:0}
.tb-div{width:1px;height:26px;background:var(--border);flex-shrink:0}
.layer-btns{display:flex;gap:5px;flex-wrap:wrap}
.lbtn{font-family:var(--fm);font-size:10px;font-weight:500;letter-spacing:.8px;padding:4px 11px;border-radius:3px;border:1px solid var(--border);background:rgba(0,170,240,.04);color:var(--text-dim);cursor:pointer;transition:all .15s;text-transform:uppercase;white-space:nowrap}
.lbtn:hover{border-color:var(--border-hi);color:var(--text)}
.lbtn.on{border-color:var(--accent);color:var(--accent);background:rgba(0,200,255,.1);box-shadow:0 0 8px rgba(0,200,255,.18)}
.lbtn.on.warn{border-color:var(--warn);color:var(--warn);background:rgba(255,107,0,.1);box-shadow:0 0 8px rgba(255,107,0,.18)}
.lbtn.on.lite{border-color:var(--watch);color:var(--watch);background:rgba(255,234,0,.08)}
#clock{font-family:var(--fm);font-size:12px;color:var(--text-dim);white-space:nowrap;flex-shrink:0}
.hud{position:absolute;z-index:900;background:var(--surface);border:1px solid var(--border);border-radius:4px;backdrop-filter:blur(18px);min-width:220px;max-width:310px;transition:border-color .2s,box-shadow .2s}
.hud:hover{border-color:var(--border-hi);box-shadow:var(--glow)}
.hud.alert-active{border-color:var(--danger);box-shadow:var(--glow-danger);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 10px rgba(255,23,68,.3)}50%{box-shadow:0 0 28px rgba(255,23,68,.7)}}
.hud-head{display:flex;align-items:center;justify-content:space-between;padding:7px 11px;border-bottom:1px solid var(--border);background:rgba(0,170,240,.03);cursor:move;user-select:none}
.hud-title{font-family:var(--fm);font-size:9.5px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:6px}
.dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 1.6s infinite;flex-shrink:0}
.dot.g{background:var(--safe)}
.dot.r{background:var(--danger);animation:blink .8s infinite}
.dot.y{background:var(--watch)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.hud-tog{font-family:var(--fm);font-size:11px;color:var(--text-dim);cursor:pointer;padding:2px 5px;border-radius:2px;transition:all .15s}
.hud-tog:hover{color:var(--accent);background:rgba(0,200,255,.1)}
.hud-body{padding:10px 11px}
.hud.collapsed .hud-body{display:none}
#hud-cond{top:62px;left:12px}
.cg{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.ci label{display:block;font-family:var(--fm);font-size:8.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-dim);margin-bottom:2px}
.ci .val{font-family:var(--fd);font-size:22px;font-weight:600;color:var(--text-hi);line-height:1}
.ci .val sup{font-size:12px;color:var(--text-dim);font-weight:400}
.cond-desc{font-family:var(--fm);font-size:9.5px;color:var(--text-dim);margin-top:7px;letter-spacing:.5px}
#hud-alerts{top:62px;right:12px;min-width:260px;max-width:310px}
#hud-alerts .hud-body{max-height:calc(100vh - 132px);overflow-y:auto}
#hud-alerts .al-item.expanded{max-height:calc(100vh - 164px);overflow-y:auto}
#hud-radar{
  position:absolute;
  left:12px;
  bottom:20px;
  z-index:900;
  min-width:270px;
  max-width:310px;
}
#hud-radar .hud-head{cursor:move}
#hud-radar.loop-active{
  border-color:var(--accent);
  box-shadow:var(--glow);
}
.al-item{border-left:3px solid var(--border);padding:6px 8px;border-radius:0 3px 3px 0;background:rgba(0,0,0,.2);margin-bottom:5px}
.al-item:last-child{margin-bottom:0}
.al-item.W{border-color:var(--danger);background:rgba(255,23,68,.07)}
.al-item.A{border-color:var(--watch);background:rgba(255,234,0,.05)}
.al-item.Y{border-color:var(--warn);background:rgba(255,107,0,.07)}
.al-event{font-family:var(--fm);font-size:9.5px;letter-spacing:.5px;font-weight:500;text-transform:uppercase}
.al-item.W .al-event{color:var(--danger)}
.al-item.A .al-event{color:var(--watch)}
.al-item.Y .al-event{color:var(--warn)}
.al-head{font-size:11.5px;color:var(--text-dim);margin-top:2px;line-height:1.3}
.al-exp{font-family:var(--fm);font-size:8.5px;color:var(--text-dim);margin-top:3px}
.no-alerts{font-family:var(--fm);font-size:10.5px;color:var(--safe);display:flex;align-items:center;gap:6px}
#hud-radar{min-width:240px}
.rtype-row{display:flex;gap:4px;margin-bottom:8px}
.rtype-btn{flex:1;font-family:var(--fm);font-size:9px;letter-spacing:1px;padding:5px;border-radius:3px;border:1px solid var(--border);background:transparent;color:var(--text-dim);cursor:pointer;text-align:center;transition:all .15s;text-transform:uppercase}
.rtype-btn.on{border-color:var(--accent);color:var(--accent);background:rgba(0,200,255,.09)}
.timeline-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.play-btn{font-family:var(--fm);font-size:9.5px;padding:3px 8px;border:1px solid var(--border);border-radius:2px;background:rgba(0,170,240,.05);color:var(--accent);cursor:pointer;transition:all .15s}
.play-btn:hover{background:rgba(0,200,255,.14);border-color:var(--border-hi)}
.tlabel{font-family:var(--fm);font-size:9px;color:var(--text-dim);white-space:nowrap}
.radar-status{font-family:var(--fm);font-size:8.5px;color:var(--text-dim);display:flex;justify-content:space-between}
.loop-load-wrap{display:none;margin:7px 0 4px}
.loop-load-wrap.active{display:block}
.loop-load-label{display:flex;justify-content:space-between;gap:8px;margin-bottom:5px;font-family:var(--fm);font-size:8px;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase}
.loop-load-track{height:5px;overflow:hidden;border-radius:999px;background:rgba(0,170,240,.12);border:1px solid rgba(0,170,240,.14)}
.loop-load-fill{height:100%;width:0%;border-radius:999px;background:linear-gradient(90deg, rgba(0,200,255,.25), var(--accent));box-shadow:0 0 10px rgba(0,200,255,.35);transition:width .18s ease}
/* station legend in HUD */
.station-tag{display:inline-block;font-family:var(--fm);font-size:8px;letter-spacing:.5px;padding:2px 5px;border-radius:2px;border:1px solid;margin:2px 2px 0 0;text-transform:uppercase;cursor:pointer;transition:all .15s}
.station-tag.wsr{border-color:rgba(0,200,255,.4);color:rgba(0,200,255,.7)}
.station-tag.tdwr{border-color:rgba(255,180,0,.4);color:rgba(255,180,0,.7)}
.station-tag.test{border-color:rgba(160,120,255,.5);color:rgba(160,120,255,.8)}
.station-tag:hover{filter:brightness(1.3);box-shadow:0 0 8px rgba(0,200,255,.22)}


/* RIGHT-SIDE ACCORDION STACK */
#right-stack{
  position:absolute;
  right:12px;
  bottom:20px;
  z-index:920;
  width:300px;
  display:flex;
  flex-direction:column;
  gap:8px;
}

#right-stack .hud{
  position:relative;
  top:auto!important;
  right:auto!important;
  bottom:auto!important;
  left:auto!important;
  transform:none!important;
  width:100%;
  min-width:0;
  max-width:none;
}

#right-stack .hud-head{
  cursor:pointer;
}

#right-stack .hud-body{
  max-height:52vh;
  overflow:auto;
}

#hud-radar,
#hud-citylayers,
#hud-stations,
#hud-cam{min-width:270px;max-width:300px}

/* CITY LAYERS MENU */
#hud-citylayers{min-width:240px;max-width:300px}
.city-layer-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:5px;
}
.city-layer-btn{
  font-family:var(--fm);
  font-size:8.5px;
  letter-spacing:.7px;
  padding:6px 5px;
  border-radius:3px;
  border:1px solid var(--border);
  background:rgba(0,170,240,.04);
  color:var(--text-dim);
  cursor:pointer;
  text-align:center;
  transition:all .15s;
  text-transform:uppercase;
}
.city-layer-btn:hover{
  border-color:var(--border-hi);
  color:var(--text);
  background:rgba(0,170,240,.08);
}
.city-layer-btn.on{
  border-color:var(--accent);
  color:var(--accent);
  background:rgba(0,200,255,.11);
  box-shadow:0 0 8px rgba(0,200,255,.16);
}
.city-layer-btn.fire.on{
  border-color:#ff3b30;
  color:#ff6b6b;
  background:rgba(255,59,48,.10);
}
.city-layer-btn.pd.on{
  border-color:#007aff;
  color:#66b2ff;
  background:rgba(0,122,255,.10);
}
.city-layer-note{
  font-family:var(--fm);
  font-size:8px;
  color:var(--text-dim);
  line-height:1.4;
  margin-top:7px;
  border-top:1px solid var(--border);
  padding-top:7px;
}

#hud-cam{bottom:20px;right:12px;min-width:270px;max-width:300px}
.cam-item{display:flex;align-items:center;gap:8px;padding:6px 7px;border:1px solid var(--border);border-radius:3px;background:rgba(0,0,0,.2);cursor:pointer;transition:all .15s;margin-bottom:5px}
.cam-item:last-child{margin-bottom:0}
.cam-item:hover{border-color:var(--border-hi);background:rgba(0,170,240,.06)}
.cam-name{font-family:var(--fm);font-size:9.5px;color:var(--text);flex:1}
.cam-dist{font-family:var(--fm);font-size:8px;color:var(--text-dim)}
.cam-thumb{width:46px;height:30px;object-fit:cover;border-radius:2px;border:1px solid var(--border);background:rgba(0,0,0,.4)}
#cam-modal{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.88);backdrop-filter:blur(8px);align-items:center;justify-content:center}
#cam-modal.open{display:flex}
.cam-modal-inner{background:var(--surface2);border:1px solid var(--border-hi);border-radius:5px;padding:16px;max-width:620px;width:90%;box-shadow:var(--glow)}
.cam-mhead{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.cam-mtitle{font-family:var(--fm);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--accent)}
.cam-mclose{font-family:var(--fm);font-size:11px;color:var(--text-dim);cursor:pointer;padding:3px 8px;border:1px solid var(--border);border-radius:3px;transition:all .15s}
.cam-mclose:hover{color:var(--danger);border-color:var(--danger)}
#cam-modal img{width:100%;border-radius:3px;border:1px solid var(--border);background:#000;display:block}
.cam-mlink{display:block;margin-top:7px;font-family:var(--fm);font-size:9.5px;color:var(--accent);text-decoration:none;letter-spacing:.5px}
.cam-mlink:hover{text-decoration:underline}
.siren-dot{width:9px;height:9px;border-radius:50%;background:rgba(0,200,255,.55);border:1.5px solid var(--accent);box-shadow:0 0 5px rgba(0,200,255,.35)}
#rbar{position:absolute;bottom:0;left:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);z-index:1100;width:0;transition:width .4s linear}
.basemap-tile{
  filter:brightness(.9) saturate(.65);
}
.radar-tile{
  image-rendering:auto;
  filter:saturate(1.2) contrast(1.08) blur(.35px);
  transform:translateZ(0);
}
.leaflet-overlay-pane svg{
  filter:none;
}
.leaflet-control-attribution{background:rgba(5,10,18,.75)!important;color:rgba(130,160,180,.5)!important;font-size:8.5px!important}
.leaflet-control-attribution a{color:rgba(0,200,255,.4)!important}
.leaflet-popup-content-wrapper{background:var(--surface2)!important;border:1px solid var(--border-hi)!important;border-radius:4px!important;color:var(--text)!important;font-family:var(--fm)!important;font-size:11px!important;box-shadow:var(--glow)!important}
.leaflet-popup-tip{background:var(--surface2)!important}
.leaflet-popup-close-button{color:var(--text-dim)!important}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--border-hi);border-radius:2px}

/* TOPBAR REFRESH CONTROL */
.top-refresh{
  display:flex;
  align-items:center;
  gap:7px;
  margin-left:auto;
  font-family:var(--fm);
  font-size:10px;
  color:var(--text-dim);
  white-space:nowrap;
}
.top-refresh-btn{
  font-family:var(--fm);
  font-size:9.5px;
  letter-spacing:.8px;
  padding:4px 9px;
  border-radius:3px;
  border:1px solid var(--border);
  background:rgba(0,170,240,.05);
  color:var(--accent);
  cursor:pointer;
  transition:all .15s;
  text-transform:uppercase;
}
.top-refresh-btn:hover{
  border-color:var(--border-hi);
  background:rgba(0,200,255,.14);
}
.last-refresh{
  color:var(--text-dim);
}

/* RIGHT SLIDE-OUT MENU */
#right-drawer{
  position:fixed;
  top:56px;
  right:12px;
  bottom:18px;
  width:330px;
  z-index:1250;
  transform:translateX(calc(100% + 24px));
  transition:transform .22s ease;
  pointer-events:none;
}
#right-drawer.open{
  transform:translateX(0);
  pointer-events:auto;
}
#right-drawer .drawer-shell{
  height:100%;
  display:flex;
  flex-direction:column;
  background:rgba(5,10,18,.96);
  border:1px solid var(--border-hi);
  border-radius:6px;
  box-shadow:0 0 28px rgba(0,0,0,.45), var(--glow);
  backdrop-filter:blur(18px);
  overflow:hidden;
}
.drawer-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:9px 11px;
  border-bottom:1px solid var(--border);
  background:rgba(0,170,240,.04);
}
.drawer-title{
  font-family:var(--fm);
  font-size:10px;
  letter-spacing:2px;
  color:var(--accent);
  text-transform:uppercase;
}
.drawer-close{
  font-family:var(--fm);
  font-size:10px;
  color:var(--text-dim);
  border:1px solid var(--border);
  border-radius:3px;
  padding:3px 7px;
  cursor:pointer;
}
.drawer-close:hover{
  color:var(--danger);
  border-color:var(--danger);
}
#right-stack{
  position:relative!important;
  right:auto!important;
  bottom:auto!important;
  z-index:auto!important;
  width:100%!important;
  gap:0!important;
  padding:8px;
  overflow:auto;
  flex:1;
}
#right-stack .hud{
  position:relative!important;
  top:auto!important;
  right:auto!important;
  bottom:auto!important;
  left:auto!important;
  transform:none!important;
  width:100%;
  min-width:0;
  max-width:none;
  margin-bottom:8px;
  box-shadow:none;
}
#right-stack .hud:last-child{
  margin-bottom:0;
}
#right-stack .hud-head{
  cursor:pointer;
}
#right-stack .hud-body{
  max-height:calc(100vh - 220px);
  overflow:auto;
}

/* Hide the old floating positioning behavior when drawer is used */
body.drawer-mode #right-stack{
  display:flex;
  flex-direction:column;
}

/* SPLIT VIEW MIRROR CURSOR */
.mirror-cursor-dot{
  width:16px;
  height:16px;
  border:2px solid #ffea00;
  border-radius:50%;
  background:rgba(255,234,0,.18);
  box-shadow:0 0 8px rgba(255,234,0,.8), 0 0 18px rgba(255,234,0,.35);
  position:relative;
}
.mirror-cursor-dot:before,
.mirror-cursor-dot:after{
  content:'';
  position:absolute;
  background:#ffea00;
  opacity:.9;
}
.mirror-cursor-dot:before{
  left:50%;
  top:-7px;
  width:2px;
  height:26px;
  transform:translateX(-50%);
}
.mirror-cursor-dot:after{
  top:50%;
  left:-7px;
  width:26px;
  height:2px;
  transform:translateY(-50%);
}


/* EXPANDABLE NWS ALERT CARDS */
.al-item{
  cursor:pointer;
  transition:all .15s;
}
.al-item:hover{
  border-color:var(--border-hi);
  background:rgba(0,170,240,.06)!important;
}
.al-item.expanded{
  background:rgba(0,0,0,.32)!important;
}
.al-full{
  display:none;
  margin-top:7px;
  padding-top:7px;
  border-top:1px solid var(--border);
  font-family:var(--fm);
  font-size:8.6px;
  color:var(--text-dim);
  line-height:1.45;
}
.al-item.expanded .al-full{
  display:block;
}
.al-meta{
  display:grid;
  grid-template-columns:74px 1fr;
  gap:3px 7px;
  margin-bottom:7px;
}
.al-meta-label{
  color:rgba(160,200,225,.55);
  text-transform:uppercase;
  letter-spacing:.7px;
}
.al-meta-value{
  color:var(--text);
}
.al-section-title{
  color:var(--accent);
  font-size:8px;
  letter-spacing:1px;
  text-transform:uppercase;
  margin:7px 0 3px;
}
.al-description{
  white-space:pre-wrap;
  max-height:160px;
  overflow:auto;
  background:rgba(0,0,0,.18);
  border:1px solid rgba(0,170,240,.12);
  border-radius:3px;
  padding:6px;
}
.al-actions{
  display:flex;
  gap:5px;
  flex-wrap:wrap;
  margin-top:7px;
}
.al-action{
  font-family:var(--fm);
  font-size:8px;
  letter-spacing:.6px;
  padding:4px 7px;
  border-radius:3px;
  border:1px solid var(--border);
  background:rgba(0,170,240,.06);
  color:var(--accent);
  cursor:pointer;
  text-transform:uppercase;
  text-decoration:none;
}
.al-action:hover{
  border-color:var(--border-hi);
  background:rgba(0,200,255,.12);
}
.al-toggle-hint{
  font-family:var(--fm);
  font-size:7.5px;
