function infraQueryUrl(baseUrl, fmt){
  const b=map.getBounds().pad(.5);
  const params=new URLSearchParams({
    where:'1=1',
    geometry:[b.getWest(),b.getSouth(),b.getEast(),b.getNorth()].join(','),
    geometryType:'esriGeometryEnvelope',
    inSR:'4326',
    spatialRel:'esriSpatialRelIntersects',
    outFields:'*',
    returnGeometry:'true',
    outSR:'4326',
    resultRecordCount:'200',
    f:fmt||'geojson'
  });
  return baseUrl.replace(/\/$/,'') + '/query?' + params.toString();
}
function infraUrl(k){ return infraQueryUrl((INFRA_CFG[k].urls||[])[0], 'geojson'); }
function esriJsonToGeoJson(data){
  const fields=(data.fields||[]).map(f=>f.name);
  return {type:'FeatureCollection',features:(data.features||[]).map((f,idx)=>{
    const attrs=f.attributes||{};
    let geom=null;
    if(f.geometry){
      if(Number.isFinite(Number(f.geometry.x))&&Number.isFinite(Number(f.geometry.y))) geom={type:'Point',coordinates:[Number(f.geometry.x),Number(f.geometry.y)]};
      else if(Array.isArray(f.geometry.points)) geom={type:'MultiPoint',coordinates:f.geometry.points};
      else if(Array.isArray(f.geometry.paths)) geom={type:'MultiLineString',coordinates:f.geometry.paths};
      else if(Array.isArray(f.geometry.rings)) geom={type:'Polygon',coordinates:f.geometry.rings};
    }
    return {type:'Feature',id:attrs.OBJECTID||attrs.FID||idx,properties:attrs,geometry:geom};
  }), _fields:fields};
}

async function fetchWithTimeout(url, opts, timeoutMs){
  const externalSignal=opts && opts.signal;
  const local=new AbortController();
  let timer=setTimeout(()=>local.abort(), timeoutMs || 9000);
  if(externalSignal){
    if(externalSignal.aborted) local.abort();
    else externalSignal.addEventListener('abort',()=>local.abort(),{once:true});
  }
  try{return await fetch(url,Object.assign({},opts||{},{signal:local.signal}));}
  finally{clearTimeout(timer);}
}

async function fetchInfraGeoJson(k, controller){
  const cfg=INFRA_CFG[k];
  let lastErr=null;
  const directBases=[...(cfg.urls||[])];
  const discovered=await discoverInfraServiceUrls(k,controller).catch(err=>{ if(err.name==='AbortError') throw err; debugLog('INFRA '+k,'Discovery failed',err,'warn'); return []; });
  const baseCandidates=[...new Set([...directBases,...discovered])];
  for(const rawBase of baseCandidates){
    const layerBases=await expandFeatureServerLayers(rawBase,controller);
    for(const base of layerBases){
      for(const fmt of ['geojson','json']){
        const url=infraQueryUrl(base,fmt);
        try{
          debugLog('INFRA '+k,'GET '+url);
          const res=await fetchWithTimeout(url,{cache:'no-store',signal:controller&&controller.signal},9000);
          const text=await res.text();
          debugLog('INFRA '+k,'HTTP '+res.status+' · '+text.length+' bytes', text.slice(0,500), res.ok?'info':'warn');
          if(!res.ok) throw new Error('HTTP '+res.status+' from '+base+' · '+text.slice(0,120));
          const data=JSON.parse(text);
          if(data.error) throw new Error((data.error.message||'ArcGIS error')+' · '+JSON.stringify(data.error.details||[]));
          const gj=fmt==='geojson'?data:esriJsonToGeoJson(data);
          gj._sourceUrl=base;
          if((gj.features||[]).length){ return gj; }
          lastErr=new Error('Endpoint returned 0 features for current bounds: '+base);
          debugLog('INFRA '+k,'Candidate returned 0 features; trying next fallback', {base, fmt}, 'warn');
          continue;
        }catch(err){
          if(err.name==='AbortError') throw err;
          lastErr=err;
          debugLog('INFRA '+k,'Candidate failed', {base, fmt, error:String(err)}, 'warn');
        }
      }
    }
  }
  throw lastErr || new Error('No infrastructure endpoints configured or discovered for '+k);
}

async function loadInfraLayers(){
  const active=Object.keys(infraOn).filter(k=>infraOn[k]);
  debugLog('INFRA','loadInfraLayers', {active, bounds: map.getBounds().toBBoxString()});
