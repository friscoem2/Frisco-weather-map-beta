  }
  lightningSocket=null;
}
function lightningConnect(urls,idx,manualRetry){
  urls = urls || ['wss://ws1.blitzortung.org/','wss://ws7.blitzortung.org/','wss://ws8.blitzortung.org/'];
  idx = idx || 0;
  if(!lightningOn||lightningPolicyBlocked)return;
  if(idx>=urls.length){
    lightningUnavailable(new Error('Direct Blitzortung browser feed connected/failed without sending strike data. Raw data access usually requires an approved login/proxy/relay, not a standalone local HTML browser client.'));
    return;
  }
  closeLightningSocketQuietly();
  const wsUrl=urls[idx];
  const session=++lightningSessionId;
  clearTimeout(lightningReconnectTimer); clearTimeout(lightningNoDataTimer);
  updateLightningUi('CONNECTING…');
  debugLog('LIGHTNING','Connecting to '+wsUrl,{attempt:idx+1,totalEndpoints:urls.length,bounds:lightningBoundsPayload()});
  try{lightningSocket=new WebSocket(wsUrl);}catch(e){lightningUnavailable(e);return;}
  lightningSocket.onopen=()=>{
    if(session!==lightningSessionId)return;
    lightningLastMessageAt=0; updateLightningUi('CONNECTED'); debugLog('LIGHTNING','WebSocket OPEN '+wsUrl); lightningSubscribe();
    lightningNoDataTimer=setTimeout(()=>{
      if(session!==lightningSessionId || !lightningOn) return;
      if(!lightningLastMessageAt){
        debugLog('LIGHTNING','OPEN but no strike MESSAGE after 60s. Trying next endpoint once. This usually means Blitzortung is not serving raw strikes to this browser client, not that Leaflet failed.',{url:wsUrl,bounds:lightningBoundsPayload()},'warn');
        closeLightningSocketQuietly();
        lightningConnect(urls,idx+1,manualRetry);
      }
    },60000);
  };
  lightningSocket.onmessage=e=>{
    if(session!==lightningSessionId)return;
    clearTimeout(lightningNoDataTimer);
    if(typeof e.data==='string'){
      if(lightningBuffer.length<5) debugLog('LIGHTNING','Message received',e.data.slice(0,700));
      handleLightningPayload(e.data);
    } else if(e.data && typeof e.data.text==='function'){
      e.data.text().then(txt=>{debugLog('LIGHTNING','Binary/blob message decoded',txt.slice(0,700));handleLightningPayload(txt);}).catch(err=>debugLog('LIGHTNING','Blob message decode failed',err,'error'));
    } else debugLog('LIGHTNING','Unsupported message type',{type:typeof e.data},'warn');
  };
  lightningSocket.onerror=e=>{
    if(session!==lightningSessionId)return;
    debugLog('LIGHTNING','WebSocket ERROR',{url:wsUrl,readyState:lightningSocket&&lightningSocket.readyState},'error');
  };
  lightningSocket.onclose=e=>{
    if(session!==lightningSessionId)return;
    clearTimeout(lightningNoDataTimer);
    debugLog('LIGHTNING','WebSocket CLOSE',{url:wsUrl,code:e.code,reason:e.reason,wasClean:e.wasClean},e.wasClean?'warn':'error');
    if(!lightningOn)return;
    if(!lightningLastMessageAt){
      lightningConnect(urls,idx+1,manualRetry);
      return;
    }
    clearTimeout(lightningReconnectTimer);
    lightningReconnectTimer=setTimeout(()=>lightningConnect(urls,0,manualRetry),30000);
    updateLightningUi('OFFLINE');
  };
}
function lightningUnavailable(err){ console.warn('Blitzortung unavailable:',err); lightningPolicyBlocked=true; closeLightningSocketQuietly(); clearTimeout(lightningReconnectTimer); clearTimeout(lightningNoDataTimer); updateLightningUi('UNAVAILABLE'); const st=document.getElementById('lightning-status'); if(st)st.innerHTML='⚡ UNAVAILABLE · direct browser feed is not sending raw strikes. Use SIM STRIKES to test rendering or add a small server/proxy for approved data access. · <a href="https://www.blitzortung.org/" target="_blank" style="color:var(--accent)">blitzortung.org</a>'; debugLog('LIGHTNING','Marked unavailable',String(err),'error'); }
function pruneLightning(){ const cutoff=Date.now()-900000; lightningBuffer=lightningBuffer.filter(s=>s.time>=cutoff).slice(-2000); }
function renderLightning(){ if(!lightningOn)return; if(!lightningRenderDirty){pruneLightning();return;} lightningRenderDirty=false; pruneLightning(); lightningLayer.clearLayers(); const now=Date.now(); lightningBuffer.forEach(s=>{const age=(now-s.time)/1000; const style=age<=60?{radius:5,color:'#ffff00',opacity:.95,fillOpacity:.85}:age<=300?{radius:3.5,color:'#ffb347',opacity:.65,fillOpacity:.5}:{radius:2,color:'rgba(255,100,0,0.35)',opacity:.35,fillOpacity:.2}; L.circleMarker([s.lat,s.lon],Object.assign({fillColor:style.color,weight:1},style)).bindPopup('⚡ Lightning Strike<br>'+new Date(s.time).toLocaleTimeString('en-US',{timeZone:'America/Chicago',hour:'numeric',minute:'2-digit',second:'2-digit'})+' CDT').addTo(lightningLayer);}); }
function setLightningLayer(on){
  lightningOn=!!on; lightningPolicyBlocked=false; debugLog('LIGHTNING',lightningOn?'Toggle ON':'Toggle OFF');
  if(lightningOn){
    if(!map.hasLayer(lightningLayer))lightningLayer.addTo(map);
    clearInterval(lightningRenderTimer); clearInterval(lightningCounterTimer);
    lightningRenderTimer=setInterval(renderLightning,500);
    lightningCounterTimer=setInterval(()=>updateLightningUi(lightningSocket&&lightningSocket.readyState===1?(lightningLastMessageAt?'LIVE':'CONNECTED'):'CONNECTING…'),5000);
    lightningConnect();
  } else {
    lightningSessionId++;
    clearInterval(lightningRenderTimer); clearInterval(lightningCounterTimer); clearTimeout(lightningReconnectTimer); clearTimeout(lightningNoDataTimer);
    closeLightningSocketQuietly(); lightningBuffer=[]; lightningLayer.clearLayers(); if(map.hasLayer(lightningLayer))map.removeLayer(lightningLayer); updateLightningUi('OFFLINE'); updateDebugStatusLine();
  }
}
function toggleLightningLayer(){ setLightningLayer(!lightningOn); }

