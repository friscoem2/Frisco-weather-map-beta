const infraDiscoveredUrlCache={};
async function discoverInfraServiceUrls(k,controller){
  if(infraDiscoveredUrlCache[k]) return infraDiscoveredUrlCache[k];
  const queries=INFRA_DISCOVERY_QUERIES[k]||[];
  const found=[];
  for(const q of queries){
    const url='https://www.arcgis.com/sharing/rest/search?'+new URLSearchParams({q:q+' AND type:"Feature Service"',f:'json',num:'8'}).toString();
    try{
      debugLog('INFRA DISCOVERY '+k,'GET '+url);
      const res=await fetchWithTimeout(url,{cache:'no-store',signal:controller&&controller.signal},9000);
      const data=await res.json();
      (data.results||[]).forEach(item=>{
        if(item.url && /FeatureServer/i.test(item.url)) found.push(item.url.replace(/\/$/,''));
      });
      if(found.length) break;
    }catch(err){
      if(err.name==='AbortError') throw err;
      debugLog('INFRA DISCOVERY '+k,'Search failed '+q,err,'warn');
    }
  }
  infraDiscoveredUrlCache[k]=[...new Set(found)];
  debugLog('INFRA DISCOVERY '+k,'Discovered '+infraDiscoveredUrlCache[k].length+' service URL(s)',infraDiscoveredUrlCache[k]);
  return infraDiscoveredUrlCache[k];
}
async function expandFeatureServerLayers(base,controller){
  const clean=base.replace(/\/$/,'');
  if(/FeatureServer\/\d+$/i.test(clean)) return [clean];
  if(!/FeatureServer$/i.test(clean)) return [clean];
  try{
    const metaUrl=clean+'?f=json';
    const res=await fetch(metaUrl,{cache:'no-store',signal:controller&&controller.signal});
    const data=await res.json();
    const layers=(data.layers||[]).slice(0,4).map(l=>clean+'/'+l.id);
    debugLog('INFRA DISCOVERY','Expanded '+clean, layers);
    return layers.length?layers:[clean+'/0'];
  }catch(err){
    if(err.name==='AbortError') throw err;
    return [clean+'/0'];
  }
}
